{
  "name": "skills-hub",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "rust:fmt": "cd src-tauri && cargo fmt --all",
    "rust:fmt:check": "cd src-tauri && cargo fmt --all -- --check",
    "rust:clippy": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "rust:test": "cd src-tauri && cargo test",
    "check": "npm run lint && npm run build && npm run rust:fmt:check && npm run rust:clippy && npm run rust:test",
    "preview": "vite preview",
    "version:set": "node scripts/version.mjs set",
    "version:sync": "node scripts/version.mjs sync",
    "version:check": "node scripts/version.mjs check",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:icon:desktop": "node scripts/tauri-icon-desktop.mjs",
    "tauri:build": "npm run version:check && tauri build",
    "tauri:build:mac:dmg": "npm run tauri:build -- --bundles dmg",
    "tauri:build:mac:universal:dmg": "npm run tauri:build -- --target universal-apple-darwin --bundles dmg",
    "tauri:build:win:exe": "npm run tauri:build -- --bundles nsis",
    "tauri:build:win:msi": "npm run tauri:build -- --bundles msi",
    "tauri:build:win:all": "npm run tauri:build -- --bundles msi,nsis",
    "tauri:build:linux:deb": "npm run tauri:build -- --bundles deb",
    "tauri:build:linux:appimage": "npm run tauri:build -- --bundles appimage",
    "tauri:build:linux:all": "npm run tauri:build -- --bundles deb,appimage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "clsx": "^2.1.1",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "react-syntax-highlighter": "^16.1.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  }
}
